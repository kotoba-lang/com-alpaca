              "market",
              "limit",
              "stop",
              "stop_limit",
              "trailing_stop"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "partially_filled",
              "filled",
              "done_for_day",
              "canceled",
              "expired",
              "replaced",
              "pending_cancel",
              "pending_replace",
              "pending_review",
              "accepted",
              "pending_new",
              "accepted_for_bidding",
              "stopped",
              "rejected",
              "suspended",
              "calculated",
              "held"
            ]
          },
          "qty": {
            "type": "string"
          },
          "timeInForce": {
            "type": "string",
            "enum": [
              "day",
              "gtc",
              "opg",
              "cls",
              "ioc",
              "fok"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
