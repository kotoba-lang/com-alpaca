  "components": {
    "schemas": {
      "Asset": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "assetClass": {
            "type": "string",
            "enum": [
              "us_equity",
              "us_option",
              "crypto",
              "crypto_perp"
            ]
          },
          "exchange": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive"
            ]
          },
          "tradable": {
            "type": "boolean"
          },
          "fractionable": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AssetCreate": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "assetClass": {
            "type": "string",
            "enum": [
              "us_equity",
              "us_option",
              "crypto",
              "crypto_perp"
            ]
          },
          "exchange": {
            "type": "string"
          },
          "status": {
